# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# How to get it:
#   1. Go to https://analytics.google.com
#   2. Admin → Create account → Create property (Web)
#   3. Set up data stream → Web → enter your site URL
#   4. Copy the Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Your deployed site URL — used for sitemap, robots.txt, and Open Graph.
# No trailing slash. For Vercel: https://your-project.vercel.app
NEXT_PUBLIC_SITE_URL=https://fluidmechanicscompanion.com

# ─── Feedback Widget ──────────────────────────────────────────────────────────
# Formspree form ID for the feedback widget (free at formspree.io)
# How to get it:
#   1. Go to https://formspree.io → sign up free
#   2. New Form → name it "Fluid Mechanics Feedback" → set your email
#   3. Copy the form ID from the URL: formspree.io/f/XXXXXXXX
NEXT_PUBLIC_FORMSPREE_ID=XXXXXXXX

# ─── Mailchimp (email list) ───────────────────────────────────────────────────
# Enables server-side email capture when engineers download PDFs.
# How to get these:
#   1. Go to mailchimp.com → sign up free (up to 500 contacts free)
#   2. Profile → Extras → API Keys → Create A Key
#   3. Audience → All contacts → Settings → Audience name & defaults → Audience ID
MAILCHIMP_API_KEY=your-api-key-here-us1
MAILCHIMP_LIST_ID=your-audience-id-here

# ─── Sentry (error monitoring) ────────────────────────────────────────────────
# Captures unhandled errors from /api/ai and /api/capture-email server-side.
# Without this set, error capture is a silent no-op — nothing breaks, you just
# won't get notified when something fails.
# How to get it:
#   1. Go to sentry.io → sign up free → New Project → platform "Next.js"
#   2. Copy the DSN shown on the project setup page
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# ─── Upstash Redis (distributed rate limiting) ────────────────────────────────
# Replaces the in-memory rate limiter so the 30 req/hour/IP limit works correctly
# across all serverless instances (not just within a single warm function).
# Free tier at upstash.com handles 10,000 commands/day — enough for substantial traffic.
# How to get these:
#   1. Go to upstash.com → create account → New Database → Redis
#   2. Copy REST URL and REST Token from the database dashboard
# Without these, the route falls back to in-memory (works, but not distributed).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
